#!/usr/bin/make -f

export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo_home
# Offline-friendly once vendor/ is present; otherwise network during build.
export DESTDIR = $(CURDIR)/debian/winetop

%:
	dh $@

override_dh_auto_build:
	cargo build --release --locked -p winetop

override_dh_auto_install:
	install -D -m 0755 target/release/winetop \
		$(DESTDIR)/usr/bin/winetop
	install -D -m 0644 man/winetop.1 \
		$(DESTDIR)/usr/share/man/man1/winetop.1
	install -D -m 0644 README.md \
		$(DESTDIR)/usr/share/doc/winetop/README.md
	install -D -m 0644 CHANGELOG.md \
		$(DESTDIR)/usr/share/doc/winetop/CHANGELOG.md

override_dh_auto_test:
	cargo test --all --locked

override_dh_auto_clean:
	cargo clean || true
	rm -rf $(CARGO_HOME)

# Preserve cargo-vendor checksum sidecars (Cargo.toml.orig) under vendor/
override_dh_clean:
	dh_clean -Xvendor
